    # A cada 10 metros, a pressão aumenta ~1 atm
    pressao_estimada = profundidade / 10
    
    # Ajusta a sensibilidade do sensor de indução para água salgada (alta condutividade)
    ajuste_salinidade = 0.85 
    
    print(f"[INFO] Operando a {profundidade}m. Pressão: {pressao_estimada} atm.")
